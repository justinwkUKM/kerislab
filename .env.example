# KerisLab Docker Compose configuration

KERISLAB_WEB_PORT=5173
KERISLAB_API_PORT=8000
KERISLAB_LITELLM_PORT=4000
KERISLAB_MINIO_PORT=9000
KERISLAB_MINIO_CONSOLE_PORT=9001

KERISLAB_POSTGRES_DB=kerislab
KERISLAB_POSTGRES_USER=kerislab
KERISLAB_POSTGRES_PASSWORD=change-me

KERISLAB_MINIO_ROOT_USER=kerislab
KERISLAB_MINIO_ROOT_PASSWORD=change-me
KERISLAB_OBJECT_STORAGE_BUCKET=kerislab-evidence
KERISLAB_REDIS_QUEUE=kerislab:scan-jobs
KERISLAB_WORKER_ID=kerislab-compose-worker-1
KERISLAB_WORKER_NAME=kerislab-compose-worker

LITELLM_MASTER_KEY=change-me
KERISLAB_BILLING_WEBHOOK_SECRET=change-me

# Google OAuth
KERISLAB_GOOGLE_CLIENT_ID=
KERISLAB_GOOGLE_CLIENT_SECRET=
KERISLAB_GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/oidc/callback

# Enterprise SSO / OIDC
KERISLAB_SSO_CLIENT_ID=
KERISLAB_SSO_CLIENT_SECRET=
KERISLAB_SSO_AUTHORIZE_URL=
KERISLAB_SSO_TOKEN_URL=
KERISLAB_SSO_REDIRECT_URI=http://localhost:5173/api/auth/oidc/callback
KERISLAB_SSO_USERINFO_URL=
KERISLAB_SSO_ISSUER_URLS=

VITE_API_BASE_URL=/api
